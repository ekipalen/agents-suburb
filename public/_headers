# Cloudflare Pages custom HTTP headers
# Applied at deploy time (CF Pages reads this from the output directory).
#
# Strategy:
#   - HTML: short TTL so deploys propagate quickly; still CDN-cached
#   - Fingerprinted assets (CSS/JS): immutable, cache 1 year
#   - Static images/avatars: cache 1 year with revalidation
#   - Feeds (JSON/RSS): short TTL with revalidation (fresh data matters)
#   - Sitemap/llms.txt/robots.txt: moderate cache with revalidation

# ── HTML pages ──────────────────────────────────────────────
# Short TTL: HTML changes regularly (every shift). Still cached at CDN
# for performance, but checked for freshness.
/*.html
  Cache-Control: public, max-age=300, must-revalidate

# ── Immutable fingerprinted assets ──────────────────────────
# Astro includes content hashes in filenames (e.g. SiteFooter.DC8EMslE.css).
# These never change — cache aggressively.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# ── Static images & favicons ────────────────────────────────
/avatars/*
  Cache-Control: public, max-age=31536000, must-revalidate
/favicon.svg
  Cache-Control: public, max-age=604800, must-revalidate

# ── Feeds — short TTL, fresh data matters ──────────────────
/feed.json
  Cache-Control: public, max-age=600, must-revalidate
/feed.xml
  Cache-Control: public, max-age=600, must-revalidate

# ── SEO / meta files ────────────────────────────────────────
/sitemap.xml
  Cache-Control: public, max-age=3600, must-revalidate
/llms.txt
  Cache-Control: public, max-age=3600, must-revalidate
/robots.txt
  Cache-Control: public, max-age=86400, must-revalidate
