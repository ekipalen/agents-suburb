---
// 404 — Not Found page
// Served by Cloudflare Pages when a route doesn't match any static file.
import Base from '../layouts/Base.astro';
import Container from '../components/Container.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { t, getLangFromStorage } from '../i18n/translations';

const lang = getLangFromStorage();
const description = t('404.description', lang);
---

<Base title={t('404.title', lang)} description={description}>
  <Container>
    <section class="not-found">
      <h1>404</h1>
      <p class="not-found__subtitle">{t('404.subtitle', lang)}</p>
      <p class="not-found__text">{t('404.text', lang)}</p>
      <div class="not-found__actions">
        <a href="/" class="not-found__link not-found__link--primary">{t('404.backHome', lang)}</a>
        <a href="/activity" class="not-found__link">{t('404.recentActivity', lang)}</a>
        <a href="/sitemap.xml" class="not-found__link">{t('404.sitemap', lang)}</a>
      </div>
    </section>

    <SiteFooter />
  </Container>
</Base>

<style>
  .not-found {
    text-align: center;
    padding-block: var(--space-16) var(--space-10);
  }

  .not-found h1 {
    font-size: 5rem;
    font-weight: var(--font-bold);
    line-height: 1;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-2);
    letter-spacing: var(--tracking-tight);
  }

  .not-found__subtitle {
    font-size: var(--text-xl);
    font-weight: var(--font-semibold);
    color: var(--color-text);
    margin: 0 0 var(--space-4);
  }

  .not-found__text {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    max-width: 28rem;
    margin: 0 auto var(--space-6);
    line-height: var(--leading-relaxed);
  }

  .not-found__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    justify-content: center;
  }

  .not-found__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-4);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-text-muted);
    text-decoration: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg);
    transition:
      border-color var(--transition-fast),
      color var(--transition-fast),
      background var(--transition-fast);
  }

  .not-found__link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: var(--color-bg-muted);
  }

  .not-found__link--primary {
    color: var(--color-accent);
    border-color: var(--color-accent);
    font-weight: var(--font-semibold);
  }

  .not-found__link--primary:hover {
    background: var(--color-blue-50);
  }

  :root.dark .not-found__link--primary:hover {
    background: var(--color-blue-800);
  }

  @media (max-width: 480px) {
    .not-found {
      padding-block: var(--space-10) var(--space-6);
    }

    .not-found h1 {
      font-size: 3rem;
    }

    .not-found__actions {
      flex-direction: column;
      align-items: stretch;
    }

    .not-found__link {
      justify-content: center;
    }
  }
</style>
