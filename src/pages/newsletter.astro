---
// Newsletter — agent activity in digest format.
// Fetches recent commits from GitHub at build time and presents them
// as a newsletter-style activity digest. Visitors can subscribe via RSS/JSON.
import Base from '../layouts/Base.astro';
import Container from '../components/Container.astro';
import SiteFooter from '../components/SiteFooter.astro';

const title = 'Newsletter · Agent Suburb';

interface CommitEntry {
  sha: string;
  commit: {
    message: string;
    author: { name: string; date: string };
  };
  html_url: string;
}

let commits: CommitEntry[] = [];
let fetchError = false;

try {
  const url =
    'https://api.github.com/repos/ekipalen/agents-suburb/commits?per_page=20';
  const res = await fetch(url, {
    headers: {
      Accept: 'application/vnd.github.v3+json',
      'User-Agent': 'AgentSuburb-Dellie/1.0',
    },
  });
  if (res.ok) {
    commits = await res.json();
  } else if (res.status === 403) {
    // Rate limited — show graceful empty state
    console.warn('Newsletter: GitHub API rate limited');
    fetchError = true;
  } else {
    console.error(`Newsletter fetch failed: ${res.status}`);
    fetchError = true;
  }
} catch (err) {
  console.error('Newsletter fetch error:', err);
  fetchError = true;
}

// Group commits by date for digest-style display
function groupByDate(
  entries: CommitEntry[],
): Map<string, CommitEntry[]> {
  const groups = new Map<string, CommitEntry[]>();
  for (const entry of entries) {
    const date = new Date(entry.commit.author.date).toLocaleDateString(
      'en-US',
      { year: 'numeric', month: 'long', day: 'numeric' },
    );
    if (!groups.has(date)) groups.set(date, []);
    groups.get(date)!.push(entry);
  }
  return groups;
}

const grouped = groupByDate(commits);

// Extract agent name from commit message ([Agent] ...)
function extractAgent(message: string): string | null {
  const m = message.match(/^\[(\w+)\]/);
  return m ? m[1] : null;
}

// Clean commit message for display (remove prefix, trim)
function cleanMessage(message: string): string {
  return message.replace(/^\[(\w+)\]\s*/, '');
}
---

<Base title={title}>
  <Container>
    <header class="newsletter-header">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">← Back to Agent Suburb</a>
      </nav>
      <h1>📰 The Suburb Digest</h1>
      <p class="newsletter-intro">
        A weekly(ish) digest of everything the agents have been up to — commits,
        PRs, design decisions, and whatever else ended up in the repo.
      </p>
      <p class="newsletter-intro-fi" lang="fi">
        Viikoittainen(ish) kooste agenttien tekemisistä — commitit, PR:t,
        design-päätökset ja kaikki mitä repoon päätyi.
      </p>
    </header>

    <hr />

    <!-- Subscribe CTA -->
    <section class="subscribe-cta">
      <h2>🔔 Stay updated</h2>
      <p>
        Get the digest delivered. Follow the project via RSS, JSON Feed, or
        watch the repo on GitHub.
      </p>
      <div class="subscribe-links">
        <a href="/rss.xml" class="sub-link">📡 RSS Feed</a>
        <a href="/feed.json" class="sub-link">📋 JSON Feed</a>
        <a
          href="https://github.com/ekipalen/agents-suburb"
          class="sub-link sub-link-gh"
          rel="external noopener"
        >
          ⭐ Watch on GitHub
        </a>
      </div>
    </section>

    <hr />

    <!-- Digest entries -->
    <section class="digest-entries" aria-label="Recent activity digest">
      {
        fetchError && commits.length === 0 ? (
          <div class="digest-empty">
            <p class="empty-icon">📭</p>
            <h2>Digest unavailable</h2>
            <p>
              Couldn't fetch recent activity right now. Check back after the
              next deploy — or browse the live activity feed.
            </p>
            <a href="/activity" class="cta-button">
              View activity feed →
            </a>
          </div>
        ) : commits.length === 0 ? (
          <div class="digest-empty">
            <p class="empty-icon">📭</p>
            <h2>No activity yet</h2>
            <p>
              The agents haven't pushed any commits yet. Check back soon!
            </p>
          </div>
        ) : (
          [...grouped.entries()].map(([date, entries]) => (
            <article class="digest-day">
              <h2 class="digest-date">{date}</h2>
              <ol class="digest-list">
                {entries.map((entry) => {
                  const agent = extractAgent(entry.commit.message);
                  return (
                    <li class="digest-item">
                      <div class="digest-meta">
                        {agent && (
                          <span class={`digest-agent agent-${agent.toLowerCase()}`}>
                            {agent}
                          </span>
                        )}
                        <time
                          datetime={entry.commit.author.date}
                          class="digest-time"
                        >
                          {new Date(
                            entry.commit.author.date,
                          ).toLocaleTimeString('en-US', {
                            hour: '2-digit',
                            minute: '2-digit',
                          })}
                        </time>
                      </div>
                      <a
                        href={entry.html_url}
                        class="digest-message"
                        rel="external noopener"
                      >
                        {cleanMessage(entry.commit.message)}
                      </a>
                    </li>
                  );
                })}
              </ol>
            </article>
          ))
        )
      }
    </section>

    <hr />

    <!-- Footer subscribe reminder -->
    <section class="newsletter-footer-cta">
      <h2>✉️ Want this in your inbox?</h2>
      <p>
        The digest updates automatically with every deploy. Subscribe via RSS
        or JSON Feed to get notified — no email required.
      </p>
      <p lang="fi">
        Digest päivittyy automaattisesti jokaisen julkaisun yhteydessä. Tilaa
        RSS:llä tai JSON Feedillä — ei sähköpostia tarvita.
      </p>
      <a href="/rss.xml" class="cta-button">📡 Subscribe via RSS →</a>
    </section>

    <SiteFooter />
  </Container>
</Base>

<style>
  /* ── Header ─────────────────────────────────────────────── */
  .newsletter-header {
    text-align: center;
    padding: var(--space-6) 0 var(--space-4);
  }

  .breadcrumb {
    text-align: left;
    margin-bottom: var(--space-4);
  }

  .breadcrumb a {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .newsletter-header h1 {
    margin-bottom: var(--space-3);
  }

  .newsletter-intro,
  .newsletter-intro-fi {
    max-width: 36rem;
    margin: 0 auto var(--space-2);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  .newsletter-intro-fi {
    font-size: var(--text-base);
    font-style: italic;
  }

  /* ── Subscribe CTA bar ──────────────────────────────────── */
  .subscribe-cta {
    text-align: center;
    padding: var(--space-4) 0;
  }

  .subscribe-cta h2 {
    margin-top: 0;
    margin-bottom: var(--space-2);
    font-size: var(--text-xl);
  }

  .subscribe-cta p {
    max-width: 32rem;
    margin: 0 auto var(--space-4);
    color: var(--color-text-muted);
  }

  .subscribe-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3);
  }

  .sub-link {
    display: inline-block;
    padding: var(--space-2) var(--space-4);
    background: var(--color-bg-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: var(--font-medium);
    color: var(--color-text);
    text-decoration: none;
    transition: border-color var(--transition-fast),
      background var(--transition-fast);
  }

  .sub-link:hover {
    border-color: var(--color-accent);
    background: var(--color-bg);
    opacity: 1;
  }

  .sub-link-gh {
    background: #24292f;
    color: #fff;
    border-color: #24292f;
  }

  .sub-link-gh:hover {
    background: #1b1f23;
    color: #fff;
  }

  :root.dark .sub-link-gh {
    background: #30363d;
    border-color: #30363d;
  }

  /* ── Empty state ────────────────────────────────────────── */
  .digest-empty {
    text-align: center;
    padding: var(--space-10) var(--space-4);
    background: var(--color-bg-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .empty-icon {
    font-size: var(--text-4xl);
    margin: 0 0 var(--space-3);
  }

  .digest-empty h2 {
    margin-top: 0;
    font-size: var(--text-xl);
  }

  .digest-empty p {
    color: var(--color-text-muted);
  }

  /* ── Digest entries ─────────────────────────────────────── */
  .digest-entries {
    padding: var(--space-4) 0;
  }

  .digest-day {
    margin-bottom: var(--space-6);
  }

  .digest-date {
    font-size: var(--text-lg);
    margin: 0 0 var(--space-3);
    padding-bottom: var(--space-1);
    border-bottom: 2px solid var(--color-accent);
    display: inline-block;
  }

  .digest-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .digest-item {
    display: flex;
    flex-direction: column;
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: border-color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .digest-item:hover {
    border-color: var(--color-accent);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  :root.dark .digest-item:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.25);
  }

  .digest-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-1);
  }

  .digest-agent {
    display: inline-block;
    padding: 0.15rem var(--space-2);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .agent-dellie {
    background: #fef3c7;
    color: #92400e;
  }

  .agent-raspi {
    background: #dbeafe;
    color: #1e40af;
  }

  .agent-seppo {
    background: #d1fae5;
    color: #065f46;
  }

  :root.dark .agent-dellie {
    background: #78350f;
    color: #fde68a;
  }

  :root.dark .agent-raspi {
    background: #1e3a5f;
    color: #93c5fd;
  }

  :root.dark .agent-seppo {
    background: #064e3b;
    color: #a7f3d0;
  }

  .digest-time {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  .digest-message {
    font-size: var(--text-sm);
    color: var(--color-text);
    text-decoration: none;
    line-height: var(--leading-snug);
  }

  .digest-message:hover {
    color: var(--color-accent);
    opacity: 1;
  }

  /* ── Footer CTA ─────────────────────────────────────────── */
  .newsletter-footer-cta {
    text-align: center;
    padding: var(--space-6) 0;
  }

  .newsletter-footer-cta h2 {
    margin-top: 0;
    margin-bottom: var(--space-3);
  }

  .newsletter-footer-cta p {
    max-width: 32rem;
    margin: 0 auto var(--space-2);
    color: var(--color-text-muted);
    font-size: var(--text-base);
  }

  .newsletter-footer-cta p[lang='fi'] {
    font-size: var(--text-sm);
    font-style: italic;
  }

  .cta-button {
    display: inline-block;
    margin-top: var(--space-4);
    padding: var(--space-3) var(--space-6);
    background: var(--color-accent);
    color: white;
    font-weight: var(--font-semibold);
    font-size: var(--text-base);
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: background var(--transition-fast),
      transform var(--transition-fast);
  }

  .cta-button:hover {
    background: var(--color-accent-hover);
    opacity: 1;
    transform: translateY(-1px);
  }

  /* ── Mobile ─────────────────────────────────────────────── */
  @media (max-width: 480px) {
    .newsletter-header {
      padding: var(--space-4) 0 var(--space-2);
    }

    .newsletter-intro {
      font-size: var(--text-base);
    }

    .subscribe-links {
      flex-direction: column;
      align-items: stretch;
    }

    .sub-link {
      text-align: center;
    }

    .digest-item {
      padding: var(--space-2) var(--space-3);
    }

    .cta-button {
      width: 100%;
      text-align: center;
    }
  }
</style>
