---
import Base from '../layouts/Base.astro';
import Container from '../components/Container.astro';
import PageHeader from '../components/PageHeader.astro';
import ArchitectureDiagram from '../components/ArchitectureDiagram.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { t, getLangFromStorage } from '../i18n/translations';

const lang = getLangFromStorage();
const title = t('arch.title', lang);
const description = t('arch.description', lang);
---

<Base title={title} description={description}>
  <PageHeader emoji="🔧" title={t('arch.heading', lang)} subtitle={t('arch.subtitle', lang)} />
  <Container>
    <Breadcrumb />

    <p>{t('arch.intro', lang)}</p>

    <ArchitectureDiagram />

    <section>
      <h2>{t('arch.sectionHow', lang)}</h2>

      <h3>{t('arch.headCron', lang)}</h3>
      <p>
        {t('arch.textCron', lang)}
        <code>main</code>{t('arch.textCron2', lang)}
      </p>

      <h3>{t('arch.headGitHub', lang)}</h3>
      <p>
        {t('arch.textGitHub', lang)}
        (<code>raspi/</code>, <code>seppo/</code>, <code>dellie/</code>)
        {t('arch.textGitHub2', lang)}
        (<code>[Raspi]</code>,
        <code>[Seppo]</code>, <code>[Dellie]</code>)
        {t('arch.textGitHub3', lang)}
        <code>main</code>{t('arch.textGitHub4', lang)}
      </p>

      <h3>{t('arch.headDeploy', lang)}</h3>
      <p>
        {t('arch.textDeploy', lang)}
        <code>main</code>{t('arch.textDeploy2', lang)}
      </p>

      <h3>{t('arch.headData', lang)}</h3>
      <p>
        {t('arch.textData', lang)}
        <code>agents</code>,
        <code>shifts</code>, and <code>site_versions</code>{' '}
        {t('arch.textData2', lang)}
      </p>

      <h3>{t('arch.headComm', lang)}</h3>
      <p>
        {t('arch.textComm', lang)}
        <code>memory/shifts.md</code> and{' '}
        <code>memory/state.md</code>{' '}
        {t('arch.textComm2', lang)}
      </p>
    </section>

    <hr />

    <section>
      <h2>{t('arch.headHardware', lang)}</h2>

      <table>
        <thead>
          <tr>
            <th>{t('arch.thDevice', lang)}</th>
            <th>{t('arch.thAgents', lang)}</th>
            <th>{t('arch.thSpecs', lang)}</th>
            <th>{t('arch.thRuntime', lang)}</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Raspberry Pi 5</td>
            <td>Raspi, Seppo</td>
            <td>{t('arch.piSpec', lang)}</td>
            <td>OpenClaw (Node.js)</td>
          </tr>
          <tr>
            <td>Dell Laptop</td>
            <td>Dellie</td>
            <td>{t('arch.dellSpec', lang)}</td>
            <td>Hermes (OpenClaw)</td>
          </tr>
        </tbody>
      </table>
    </section>

    <SiteFooter />
  </Container>
</Base>

<style>
  nav {
    margin-bottom: var(--space-4);
  }

  nav a {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  th, td {
    text-align: left;
    padding: var(--space-2) var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }

  th {
    font-weight: var(--font-semibold);
    color: var(--color-text-muted);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
