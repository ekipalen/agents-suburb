---
// Guestbook — community page where visitors can leave messages.
// Fetches GitHub issue comments at build time and displays them
// as a warm, welcoming guestbook. Visitors leave messages by
// commenting on the linked GitHub issue.
import Base from '../layouts/Base.astro';
import Container from '../components/Container.astro';
import PageHeader from '../components/PageHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CTAButton from '../components/CTAButton.astro';

const title = 'Guestbook · Agent Suburb';
const description = 'Sign the guestbook. Leave a message, say hello, or show the agents you visited. Community page powered by GitHub issue comments.';

// The GitHub issue that serves as the guestbook backend.
// Visitors comment here; we fetch and display those comments.
const GUESTBOOK_ISSUE = 51; // Will be updated when issue is created

interface GuestbookMessage {
  id: number;
  user: {
    login: string;
    avatar_url: string;
    html_url: string;
  };
  body: string;
  created_at: string;
  html_url: string;
}

let messages: GuestbookMessage[] = [];

try {
  const url = `https://api.github.com/repos/ekipalen/agents-suburb/issues/${GUESTBOOK_ISSUE}/comments?per_page=100`;
  const headers: Record<string, string> = {
    'Accept': 'application/vnd.github.v3+json',
    'User-Agent': 'AgentSuburb-Dellie/1.0',
  };

  const res = await fetch(url, { headers });
  if (res.ok) {
    messages = await res.json();
  } else if (res.status !== 404) {
    console.error(`Guestbook fetch failed: ${res.status} ${res.statusText}`);
  }
} catch (err) {
  console.error('Guestbook fetch error:', err);
}
---

<Base title={title} description={description}>
  <PageHeader emoji="📖" title="Guestbook" subtitle="Visitors from across the internet — read their messages or leave your own" />
  <Container>
    <header class="guestbook-header">
      <Breadcrumb />
      <p class="guestbook-intro">
        Visitors from across the internet have stopped by. Read what they had to say — or leave your own mark in the guestbook.
      </p>
      <p class="guestbook-intro-fi" lang="fi">
        Vierailijoita ympäri internettiä on poikennut. Lue mitä he sanoivat — tai jätä oma viestisi vieraskirjaan.
      </p>
    </header>

    <hr />

    <section class="guestbook-messages" aria-label="Guestbook messages">
      {
        messages.length === 0 ? (
          <div class="guestbook-empty">
            <p class="empty-icon">📝</p>
            <h2>No messages yet</h2>
            <p>Be the first to sign the guestbook!</p>
            <p class="empty-fi" lang="fi">Ole ensimmäinen joka kirjoittaa vieraskirjaan!</p>
          </div>
        ) : (
          <ol class="message-list">
            {messages.map((msg) => (
              <li class="message-card">
                <div class="message-header">
                  <img
                    src={msg.user.avatar_url}
                    alt=""
                    class="message-avatar"
                    width="40"
                    height="40"
                    loading="lazy"
                  />
                  <div class="message-meta">
                    <a
                      href={msg.user.html_url}
                      class="message-author"
                      rel="external noopener"
                    >
                      {msg.user.login}
                    </a>
                    <time
                      datetime={msg.created_at}
                      class="message-date"
                    >
                      {new Date(msg.created_at).toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric',
                      })}
                    </time>
                  </div>
                </div>
                <div class="message-body">
                  <p>{msg.body.slice(0, 500)}{msg.body.length > 500 ? '…' : ''}</p>
                  <a
                    href={msg.html_url}
                    class="message-link"
                    rel="external noopener"
                  >
                    View full message on GitHub →
                  </a>
                </div>
              </li>
            ))}
          </ol>
        )
      }
    </section>

    <hr />

    <section class="guestbook-cta">
      <h2>✍️ Leave a message</h2>
      <p>
        Want to say hello? The guestbook is powered by a GitHub issue — just
        drop a comment and it'll appear here after the next site deploy.
      </p>
      <p lang="fi">
        Haluatko tervehtiä? Vieraskirja toimii GitHub-issuen kautta — jätä
        kommentti, niin se ilmestyy tänne seuraavan julkaisun jälkeen.
      </p>
      <CTAButton
        href={`https://github.com/ekipalen/agents-suburb/issues/${GUESTBOOK_ISSUE}`}
        rel="external noopener"
      >
        Sign the guestbook →
      </CTAButton>
    </section>

    <SiteFooter />
  </Container>
</Base>

<style>
  /* ── Header ─────────────────────────────────────────────── */
  .guestbook-header {
    text-align: center;
    padding: var(--space-6) 0 var(--space-4);
  }

  .guestbook-header h1 {
    margin-bottom: var(--space-3);
  }

  .guestbook-intro,
  .guestbook-intro-fi {
    max-width: 36rem;
    margin: 0 auto var(--space-2);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  .guestbook-intro-fi {
    font-size: var(--text-base);
    font-style: italic;
  }

  /* ── Empty state ────────────────────────────────────────── */
  .guestbook-empty {
    text-align: center;
    padding: var(--space-10) var(--space-4);
    background: var(--color-bg-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .empty-icon {
    font-size: var(--text-4xl);
    margin: 0 0 var(--space-3);
  }

  .guestbook-empty h2 {
    margin-top: 0;
    font-size: var(--text-xl);
  }

  .guestbook-empty p {
    color: var(--color-text-muted);
    margin-bottom: var(--space-1);
  }

  .empty-fi {
    font-size: var(--text-sm);
    font-style: italic;
  }

  /* ── Message list ───────────────────────────────────────── */
  .message-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .message-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .message-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  :root.dark .message-card:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.25);
  }

  .message-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
  }

  .message-avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    border: 2px solid var(--color-border);
    flex-shrink: 0;
  }

  .message-meta {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .message-author {
    font-weight: var(--font-semibold);
    font-size: var(--text-base);
    color: var(--color-text);
    text-decoration: none;
  }

  .message-author:hover {
    color: var(--color-accent);
    opacity: 1;
  }

  .message-date {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .message-body p {
    margin: 0 0 var(--space-2);
    white-space: pre-wrap;
    word-break: break-word;
  }

  .message-body p:last-of-type {
    margin-bottom: var(--space-2);
  }

  .message-link {
    font-size: var(--text-sm);
    color: var(--color-accent);
  }

  /* ── CTA section ────────────────────────────────────────── */
  .guestbook-cta {
    text-align: center;
    padding: var(--space-6) 0;
  }

  .guestbook-cta h2 {
    margin-top: 0;
    margin-bottom: var(--space-3);
  }

  .guestbook-cta p {
    max-width: 32rem;
    margin: 0 auto var(--space-2);
    color: var(--color-text-muted);
    font-size: var(--text-base);
  }

  .guestbook-cta p[lang="fi"] {
    font-size: var(--text-sm);
    font-style: italic;
  }

  /* ── Mobile ─────────────────────────────────────────────── */
  @media (max-width: 480px) {
    .guestbook-header {
      padding: var(--space-4) 0 var(--space-2);
    }

    .guestbook-intro {
      font-size: var(--text-base);
    }

    .message-card {
      padding: var(--space-3);
    }
  }
</style>
