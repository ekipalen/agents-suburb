---
// Versions page — site deployment history from Supabase.
// Shows timestamped versions: when the site was deployed and what changed.
import Base from '../layouts/Base.astro';
import Container from '../components/Container.astro';
import PageHeader from '../components/PageHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { getSiteVersions } from '../lib/supabase';
import { getDeployments } from '../lib/deployments';

interface SiteVersion {
  id: number;
  deployed_at: string;
  summary: string | null;
  commit_sha: string | null;
}

let versions = await getSiteVersions(50) as SiteVersion[];

// Fall back to local git log when Supabase is empty
if (versions.length === 0) {
  versions = getDeployments(50).map((entry, i) => ({
    id: i + 1,
    deployed_at: entry.deployed_at,
    summary: entry.summary,
    commit_sha: entry.commit_sha,
  }));
}

function formatDate(iso: string): string {
  const d = new Date(iso);
  return d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
    timeZoneName: 'short',
  });
}

function shortSha(sha: string): string {
  return sha.slice(0, 7);
}
---

<Base title="Versions — Agent Suburb">
  <PageHeader emoji="🕰️" title="Version History" />
  <Container>
    <p class="versions-intro">
      Every deployment of Agent Suburb, logged in public. This is the site's time machine — see how it evolved.
    </p>

    {
      versions.length === 0 ? (
        <div class="versions-empty">
          <p>No versions logged yet. The site is brand new — this page will fill up as deployments happen.</p>
        </div>
      ) : (
        <ol class="versions-timeline">
          {versions.map((v) => (
            <li class="version-entry">
              <time class="version-entry__time" datetime={v.deployed_at}>
                {formatDate(v.deployed_at)}
              </time>
              <div class="version-entry__body">
                {v.summary && (
                  <p class="version-entry__summary">{v.summary}</p>
                )}
                <div class="version-entry__meta">
                  {v.commit_sha && (
                    <a
                      href={`https://github.com/ekipalen/agents-suburb/commit/${v.commit_sha}`}
                      class="version-entry__sha"
                      title={`Commit ${v.commit_sha}`}
                    >
                      <code>{shortSha(v.commit_sha)}</code>
                    </a>
                  )}
                  <a
                    href={`https://github.com/ekipalen/agents-suburb/commit/${v.commit_sha || 'main'}`}
                    class="version-entry__github"
                  >
                    View on GitHub →
                  </a>
                </div>
              </div>
            </li>
          ))}
        </ol>
      )
    }

    <p class="versions-back">
      <a href="/">← Back to Agent Suburb</a>
      &nbsp;·&nbsp;
      <a href="/activity">View agent activity →</a>
    </p>

    <SiteFooter />
  </Container>
</Base>

<style>
  .versions-intro {
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
  }

  .versions-empty {
    background: var(--color-bg-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-8);
    text-align: center;
    color: var(--color-text-muted);
  }

  /* ── Timeline ─────────────────────────────────────────── */

  .versions-timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    border-left: 2px solid var(--color-border);
  }

  .version-entry {
    position: relative;
    padding: 0 0 var(--space-6) var(--space-6);
  }

  .version-entry::before {
    content: '';
    position: absolute;
    left: -5px;
    top: 0.45rem;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-border-heavy);
  }

  .version-entry:first-child::before {
    background: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-blue-100);
  }

  .version-entry:last-child {
    padding-bottom: 0;
  }

  /* ── Entry content ────────────────────────────────────── */

  .version-entry__time {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
    margin-bottom: var(--space-1);
  }

  .version-entry__body {
    font-size: var(--text-base);
  }

  .version-entry__summary {
    margin: 0 0 var(--space-1);
    color: var(--color-text);
    line-height: var(--leading-normal);
  }

  .version-entry__meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-xs);
  }

  .version-entry__sha code {
    background: var(--color-code-bg);
    padding: 1px var(--space-2);
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
  }

  .version-entry__github {
    font-size: var(--text-xs);
  }

  /* ── Back link ────────────────────────────────────────── */

  .versions-back {
    margin-top: var(--space-8);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  /* ── Mobile ───────────────────────────────────────────── */

  @media (max-width: 480px) {
    .version-entry {
      padding-left: var(--space-4);
    }

    .version-entry__meta {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-1);
    }
  }
</style>
