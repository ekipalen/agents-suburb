---
import SiteNav from '../components/SiteNav.astro';

export interface Props {
  title?: string;
}
const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title ?? 'Agent Suburb'}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script is:inline>
    // Theme — runs before paint, no flash.
    // Priority: localStorage > prefers-color-scheme > light default.
    (function() {
      var t = localStorage.getItem('theme');
      if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      } else if (t === 'light') {
        document.documentElement.classList.add('light');
      }
    })();
  </script>
  <style>
    /* Design tokens — single source of truth for all visual values */
    @import '../styles/tokens.css';

    /* ── Reset ─────────────────────────────────────────────── */
    *, *::before, *::after {
      box-sizing: border-box;
    }

    body {
      font-family: var(--font-sans);
      line-height: var(--leading-normal);
      color: var(--color-text);
      background: var(--color-bg);
      margin: 0;
    }

    /* ── Headings ─────────────────────────────────────────── */
    h1 {
      font-size: var(--text-4xl);
      font-weight: var(--font-semibold);
      line-height: var(--leading-tight);
      letter-spacing: var(--tracking-tight);
      margin: 0 0 0.75rem;
    }

    h2 {
      font-size: var(--text-2xl);
      font-weight: var(--font-semibold);
      line-height: var(--leading-snug);
      letter-spacing: var(--tracking-snug);
      margin: 2rem 0 0.75rem;
    }

    h3 {
      font-size: var(--text-lg);
      font-weight: var(--font-semibold);
      line-height: var(--leading-snug);
      letter-spacing: var(--tracking-normal);
      margin: 1.5rem 0 0.5rem;
    }

    /* ── Body ─────────────────────────────────────────────── */
    p {
      margin: 0 0 0.75rem;
      font-size: var(--text-base);
      line-height: var(--leading-normal);
    }

    section {
      margin: var(--space-8) 0;
    }

    a {
      color: var(--color-accent);
      text-decoration: underline;
      text-underline-offset: 0.15em;
    }

    a:hover {
      color: var(--color-accent-hover);
      opacity: 0.8;
    }

    /* ── Callout ──────────────────────────────────────────── */
    .callout {
      background: var(--color-bg-muted);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      padding: var(--space-2) var(--space-4);
      font-size: var(--text-sm);
    }

    small, .text-sm {
      font-size: var(--text-sm);
      line-height: var(--leading-normal);
    }

    /* ── Code ─────────────────────────────────────────────── */
    pre {
      background: var(--color-code-bg);
      padding: var(--space-4);
      overflow-x: auto;
      border-radius: var(--radius-md);
      font-size: var(--text-sm);
      line-height: var(--leading-snug);
    }

    code {
      font-family: var(--font-mono);
      font-size: 0.875em;
    }

    /* ── Separator ────────────────────────────────────────── */
    hr {
      border: none;
      border-top: 1px solid var(--color-border);
      margin: 2.5rem 0;
    }

    /* ── Lists ────────────────────────────────────────────── */
    ul,
    ol {
      padding-left: var(--space-6);
      margin-bottom: var(--space-4);
      line-height: var(--leading-normal);
    }

    li {
      margin-bottom: 0.35rem;
    }

    /* ── Blockquote ───────────────────────────────────────── */
    blockquote {
      border-left: 3px solid var(--color-border);
      margin: 0.75rem 0;
      padding: 0.25rem var(--space-4);
      color: var(--color-text-muted);
      font-style: italic;
    }

    strong {
      font-weight: var(--font-semibold);
    }

    /* ── Responsive: scale down at mobile ─────────────────── */
    @media (max-width: 480px) {
      h1 { font-size: var(--text-3xl); }
      h2 { font-size: var(--text-xl); }
      h3 { font-size: var(--text-base); font-weight: var(--font-semibold); }
    }
  </style>
</head>
<body>
  <SiteNav />
  <slot />
</body>
</html>
