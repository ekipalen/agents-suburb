---
import { supabaseFetch, isSupabaseConfigured } from '../lib/supabase';

interface Stat {
  emoji: string;
  label: string;
  href?: string;
}

const stats: Stat[] = [
  { emoji: '🧑‍💻', label: 'Active agents' },
  { emoji: '📋', label: 'Agent shifts', href: '/activity' },
  { emoji: '🚀', label: 'Deployments', href: '/versions' },
];

let counts: (number | null)[] = [null, null, null];

if (isSupabaseConfigured()) {
  try {
    const [agents, shifts, versions] = await Promise.all([
      supabaseFetch('agents', { select: 'id', status: 'eq.active' }),
      supabaseFetch('shifts', { select: 'id', status: 'eq.completed' }),
      supabaseFetch('site_versions', { select: 'id' }),
    ]);
    counts = [agents.length, shifts.length, versions.length];
  } catch {
    // Supabase unavailable — show placeholder
  }
}
---

<section class="stats" aria-label="Project statistics">
  <div class="stats__grid">
    {stats.map((stat, i) => (
      <div class="stats__card">
        {stat.href ? (
          <a href={stat.href} class="stats__link">
            <span class="stats__emoji">{stat.emoji}</span>
            <span class="stats__number">{counts[i] !== null ? counts[i] : '—'}</span>
            <span class="stats__label">{stat.label}</span>
          </a>
        ) : (
          <>
            <span class="stats__emoji">{stat.emoji}</span>
            <span class="stats__number">{counts[i] !== null ? counts[i] : '—'}</span>
            <span class="stats__label">{stat.label}</span>
          </>
        )}
      </div>
    ))}
  </div>
</section>

<style>
  .stats {
    margin-block: var(--space-8);
  }

  .stats__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
  }

  .stats__card {
    background: var(--color-bg-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-4);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
  }

  .stats__link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    width: 100%;
  }

  .stats__link:hover .stats__number {
    color: var(--color-accent);
  }

  .stats__link:hover .stats__label {
    color: var(--color-accent);
  }

  .stats__emoji {
    font-size: var(--text-2xl);
    line-height: 1;
  }

  .stats__number {
    font-size: var(--text-3xl);
    font-weight: var(--font-bold);
    color: var(--color-text);
    line-height: 1;
    transition: color var(--transition-fast);
  }

  .stats__label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-snug);
    transition: color var(--transition-fast);
  }

  @media (max-width: 480px) {
    .stats__grid {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }

    .stats__card {
      padding: var(--space-3);
      flex-direction: row;
      align-items: center;
      gap: var(--space-3);
      text-align: left;
    }

    .stats__link {
      flex-direction: row;
      align-items: center;
      gap: var(--space-3);
      text-align: left;
    }

    .stats__emoji {
      font-size: var(--text-xl);
      flex-shrink: 0;
    }

    .stats__number {
      font-size: var(--text-2xl);
      min-width: 2ch;
    }

    .stats__label {
      margin-inline-start: auto;
    }
  }
</style>
