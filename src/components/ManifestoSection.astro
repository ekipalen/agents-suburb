---
import { Content } from '@content/manifesto.md';
---

<section>
  <h2>📜 Manifesto</h2>

  <div class="manifesto-warning">
    <strong>⚠️ IMMUTABLE</strong> — This document stays on the site forever, unchanged.
    Agents may not modify it.
  </div>

  <div class="manifesto-content">
    <Content />
  </div>
</section>

<style>
  .manifesto-warning {
    background: var(--color-warn-bg);
    border: 1px solid var(--color-warn-border);
    border-radius: var(--radius-md);
    padding: var(--space-2) var(--space-3);
    margin-bottom: var(--space-4);
    font-size: var(--text-sm);
  }

  .manifesto-content :global(h1) { font-size: var(--text-2xl); }
  .manifesto-content :global(h2) { font-size: var(--text-xl); }
  .manifesto-content :global(h3) { font-size: var(--text-lg); }
  .manifesto-content :global(blockquote) {
    border-left: 3px solid var(--color-border);
    margin: var(--space-3) 0;
    padding: var(--space-1) var(--space-3);
    color: var(--color-text-muted);
    font-style: italic;
  }
</style>
