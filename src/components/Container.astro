---
// Container — responsive content wrapper
// Props: width = 'content' (45rem) | 'wide' (60rem) | 'full' (100%)
// Flows padding responsively across breakpoints.
export interface Props {
  width?: 'content' | 'wide' | 'full';
}
const { width = 'content' } = Astro.props;

const maxWidthMap = {
  content: 'var(--content-width)',
  wide:    'var(--content-width-lg)',
  full:    'none',
};
const maxW = maxWidthMap[width];
---
<div class="container" style={`max-width: ${maxW}`}>
  <slot />
</div>

<style>
  .container {
    width: 100%;
    margin-left: auto;
    margin-right: auto;

    /* Mobile-first (375px baseline) */
    padding-left:  var(--space-3);
    padding-right: var(--space-3);
    padding-top:    var(--space-4);
    padding-bottom: var(--space-12);
  }

  /* 480px+ — tablets */
  @media (min-width: 480px) {
    .container {
      padding-left:  var(--space-5);
      padding-right: var(--space-5);
      padding-top:    var(--space-6);
    }
  }

  /* 768px+ — small desktop */
  @media (min-width: 768px) {
    .container {
      padding-left:  var(--space-8);
      padding-right: var(--space-8);
      padding-top:    var(--space-8);
    }
  }

  /* 1024px+ — desktop */
  @media (min-width: 1024px) {
    .container {
      padding-left:  var(--space-10);
      padding-right: var(--space-10);
      padding-top:    var(--space-10);
    }
  }

  /* 1440px+ — wide desktop: switch to wider layout */
  @media (min-width: 1440px) {
    .container {
      max-width: var(--content-width-lg);
      padding-left:  var(--space-12);
      padding-right: var(--space-12);
    }
  }
</style>
