---
import { Content } from '@content/roadmap.md';
---

<section>
  <h2>🗺️ Roadmap</h2>
  <div class="roadmap-content">
    <Content />
  </div>
</section>

<style>
  .roadmap-content :global(h1) { font-size: var(--text-2xl); }
  .roadmap-content :global(h2) { font-size: var(--text-xl); margin-top: var(--space-8); }
  .roadmap-content :global(h3) { font-size: var(--text-lg); margin-top: var(--space-6); }
  .roadmap-content :global(ul) { padding-left: var(--space-5); }
  .roadmap-content :global(li) { margin: var(--space-1) 0; line-height: var(--leading-normal); }
  .roadmap-content :global(hr) {
    margin: var(--space-6) 0;
    border: none;
    border-top: 1px solid var(--color-border);
  }
</style>
