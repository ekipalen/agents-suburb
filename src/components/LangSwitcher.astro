---
// LangSwitcher — language toggle button.
// Client-side only: reads/writes localStorage, toggles between fi/en.
// Updates visible text in any element with [data-i18n] attributes.
---
<button
  class="lang-switcher"
  title="Switch language"
  data-lang-switcher
>
  🇫🇮 Suomi
</button>

<script>
  (function () {
    const btn = document.querySelector('[data-lang-switcher]') as HTMLElement | null;
    if (!btn) return;

    const labels: Record<string, Record<string, string>> = {
      fi: { fi: '🇬🇧 English', en: '🇬🇧 English' },
      en: { fi: '🇫🇮 Suomi', en: '🇫🇮 Suomi' },
    };

    // Read initial lang from localStorage
    let lang = (localStorage.getItem('lang') || 'en') as 'fi' | 'en';
    applyLang(lang, btn);

    btn.addEventListener('click', () => {
      lang = lang === 'fi' ? 'en' : 'fi';
      localStorage.setItem('lang', lang);
      applyLang(lang, btn);
    });

    function applyLang(lang: 'fi' | 'en', btn: HTMLElement) {
      // Update button label
      const label = labels[lang];
      btn.textContent = label ? label[lang] : `Switch to ${lang}`;

      // Update html lang attribute
      document.documentElement.lang = lang;

      // Update all elements with data-i18n attribute
      document.querySelectorAll('[data-i18n]').forEach((el) => {
        const key = el.getAttribute('data-i18n');
        if (!key) return;
        const translations = getTranslations();
        const text = translations[key]?.[lang];
        if (text !== undefined) el.textContent = text;
      });
    }

    function getTranslations(): Record<string, Record<string, string>> {
      // This is a generated lookup injected at build time — see Base.astro
      return (window as any).__i18n || {};
    }
  })();
</script>

<style>
  .lang-switcher {
    display: inline;
    background: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 2px 6px;
    cursor: pointer;
    font-size: var(--text-sm);
    line-height: 1;
    vertical-align: middle;
    transition: border-color var(--transition-fast);
  }

  .lang-switcher:hover {
    border-color: var(--color-accent);
  }
</style>
