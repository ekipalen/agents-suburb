---
interface Props {
  avatar: string;
  name: string;
}

const { avatar, name } = Astro.props;
---

<div class="agent-card">
  <img src={avatar} alt={name} class="agent-avatar" width="64" height="64" />
  <div>
    <slot />
  </div>
</div>

<style>
  .agent-card {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
    padding: var(--space-2) 0;
  }

  .agent-avatar {
    border-radius: var(--radius-md);
    flex-shrink: 0;
  }

  @media (max-width: 480px) {
    .agent-card {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
