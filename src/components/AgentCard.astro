---
import Badge from './Badge.astro';

export interface Props {
  avatar: string;
  name: string;
  variant?: 'raspi' | 'seppo' | 'dellie' | 'eki';
  role?: string;
}

const { avatar, name, variant, role } = Astro.props;
---

<div class="agent-card">
  <img
    src={avatar}
    alt={name}
    class="agent-card__avatar"
    width="72"
    height="72"
    loading="lazy"
  />
  <div class="agent-card__body">
    <div class="agent-card__header">
      <strong class="agent-card__name">{name}</strong>
      {role && <Badge variant={variant}>{role}</Badge>}
    </div>
    <div class="agent-card__content">
      <slot />
    </div>
  </div>
</div>

<style>
  .agent-card {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-4);
    background: var(--color-bg-muted);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-4);
  }

  .agent-card__avatar {
    border-radius: var(--radius-md);
    flex-shrink: 0;
    object-fit: cover;
  }

  .agent-card__body {
    flex: 1;
    min-width: 0;
  }

  .agent-card__header {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }

  .agent-card__name {
    font-size: var(--text-base);
    font-weight: var(--font-semibold);
    color: var(--color-text);
    line-height: var(--leading-snug);
  }

  .agent-card__content {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }

  .agent-card__content :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .agent-card__content :global(a:hover) {
    color: var(--color-accent-hover);
    opacity: 0.8;
  }

  .agent-card__content :global(br) {
    display: block;
    content: '';
    margin-bottom: 0.25rem;
  }

  @media (max-width: 480px) {
    .agent-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: var(--space-3);
      gap: var(--space-3);
    }

    .agent-card__avatar {
      width: 64px;
      height: 64px;
    }

    .agent-card__header {
      justify-content: center;
    }
  }
</style>
